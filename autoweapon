-- AUTO LOAD CONFIG sau 5 giây
------------------------------------------------
task.spawn(function()
    statusLbl.Text="⏳ Chờ 5s để tải config..."
    statusLbl.TextColor3=Color3.fromRGB(200,200,100)

    -- Đếm ngược hiển thị
    for i = 5, 1, -1 do
        if destroyed then return end
        saveLbl.Text="⏳ Tải config sau "..i.."s..."
        saveLbl.TextColor3=Color3.fromRGB(200,200,80)
        task.wait(1)
    end

    if destroyed then return end

    local data = loadConfig()
    if data and data.targetType and data.targetType ~= "" then
        applyConfig(data)
    else
        statusLbl.Text="Chọn vũ khí bên dưới"
        statusLbl.TextColor3=Color3.fromRGB(180,180,200)
        saveLbl.Text="💾 Chưa có config"
        saveLbl.TextColor3=Color3.fromRGB(90,90,110)
        print("[BF Weapon] Không tìm thấy config, chờ người dùng chọn.")
    end
end)

