------------------------------------------------
-- applyConfig: Áp dụng config lên GUI + state
------------------------------------------------
applyConfig = function(data)
    if not data then return end
    local t = data.targetType
    local r = data.running

    if t and t ~= "" then
        -- Tìm wdata tương ứng
        local wdata_found = nil
        for _, wdata in ipairs(weaponTypes) do
            if wdata.type == t then wdata_found = wdata break end
        end

        if wdata_found then
            -- Reset màu nút
            for _, b in pairs(wBtns) do
                b.BackgroundColor3=Color3.fromRGB(25,25,38)
            end

            targetType = t
            local wb = wBtns[t]
            if wb then wb.BackgroundColor3 = wdata_found.color end

            if r then
                running = true
                startLoop()
                toggleBtn.Text="▶  Đang giữ: "..targetType
                toggleBtn.BackgroundColor3=Color3.fromRGB(0,180,70)
                toggleBtn.TextColor3=Color3.fromRGB(255,255,255)
                statusLbl.Text="🔄 Đã khôi phục từ config: "..targetType
                statusLbl.TextColor3=Color3.fromRGB(140,255,140)
            else
                running = false
                toggleBtn.Text="⏸  Tạm dừng: "..targetType
                toggleBtn.BackgroundColor3=Color3.fromRGB(160,100,0)
                toggleBtn.TextColor3=Color3.fromRGB(255,230,150)
                statusLbl.Text="⏸ Đã khôi phục (tạm dừng): "..targetType
                statusLbl.TextColor3=Color3.fromRGB(200,160,60)
            end

            saveLbl.Text="💾 Config: "..t.." | "..(r and "ON" or "OFF")
            saveLbl.TextColor3=Color3.fromRGB(100,200,255)
            print("[BF Weapon] Config khôi phục: type="..t.." running="..tostring(r))
        end
    end
end

