-- CONFIG FILE (Delta executor dùng writefile/readfile)
------------------------------------------------
local CONFIG_PATH = "BFWeaponEquip_Config.json"

local function saveConfig()
    local data = {
        targetType = targetType or "",
        running    = running or false,
    }
    local ok = pcall(function()
        writefile(CONFIG_PATH, game:GetService("HttpService"):JSONEncode(data))
    end)
    if ok then
        print("[BF Weapon] Config đã lưu:", CONFIG_PATH)
    end
end

local function loadConfig()
    local ok, raw = pcall(readfile, CONFIG_PATH)
    if not ok or not raw or raw == "" then return nil end
    local ok2, data = pcall(function()
        return game:GetService("HttpService"):JSONDecode(raw)
    end)
    if ok2 and data then return data end
    return nil
end

